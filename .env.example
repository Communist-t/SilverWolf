# 大模型 API 配置
# 支持 OpenAI 兼容协议，填入你的 API Key 和 baseURL 即可
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# 如果本机需要代理才能访问模型服务，取消注释并填写代理地址
# LLM_PROXY_URL=http://127.0.0.1:7897

# 服务监听地址和端口
# 默认仅监听本机；部署到容器或服务器时可显式改为 0.0.0.0
HOST=127.0.0.1
PORT=3000
# 单次聊天请求最长执行时间（毫秒）
REQUEST_TIMEOUT_MS=90000

# 日志等级：debug / info / warn / error
LOG_LEVEL=info

# 可选：公网部署时保护聊天和会话接口，至少 16 位且不能包含空格
# APP_AUTH_TOKEN=replace-with-a-long-random-token

# 用户会话签名密钥（用于生成登录 token）
# JWT_SECRET=replace-with-a-random-secret

# 邮箱 SMTP 配置（用于发送注册验证码）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=银狼 Agent <noreply@example.com>

# SQLite 数据存储
# 默认会使用 ./data/silver-wolf.sqlite
# DATA_DIR=./data
# DATABASE_PATH=./data/silver-wolf.sqlite

# 联网搜索工具
# WEB_SEARCH_PROVIDER 可选：auto / tavily / brave / html
# auto 会优先使用已配置 Key 的正式搜索 API，否则回退到 DuckDuckGo/Bing HTML
WEB_SEARCH_PROVIDER=auto
# TAVILY_API_KEY=tvly-your-api-key
# BRAVE_SEARCH_API_KEY=bsa-your-api-key
# 如搜索也需要走代理，可以单独设置；不设置时会复用 LLM_PROXY_URL
# WEB_SEARCH_PROXY_URL=http://127.0.0.1:7897
# 单次搜索超时、重试次数和内存缓存时间
WEB_SEARCH_TIMEOUT_MS=20000
WEB_SEARCH_RETRIES=2
WEB_SEARCH_CACHE_TTL_MS=300000
