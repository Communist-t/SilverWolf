{
  "name": "silver-wolf-agent",
  "version": "0.1.0",
  "description": "银狼（Silver Wolf）AI 对话 Agent —— 基于崩坏星穹铁道角色",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx --watch src/index.ts",
    "chat": "tsx src/cli.ts",
    "prestart": "npm run build",
    "start": "node dist/src/index.js",
    "prestart:chat": "npm run build",
    "start:chat": "node dist/src/cli.js",
    "build": "tsc",
    "test": "tsx --test --test-concurrency=1 tests/*.test.ts",
    "test:intents": "tsx scripts/check-tool-router.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.0",
    "hono": "^4.0.0",
    "https-proxy-agent": "^9.0.0",
    "nodemailer": "^8.0.11",
    "openai": "^4.70.0",
    "pg": "^8.22.0",
    "undici": "^7.8.0"
  },
  "devDependencies": {
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@phosphor-icons/web": "^2.1.2",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
